# Secret (≥ 32 chars) to sign session JWTs.

export AUTH_SECRET="your-secret-here-1234567890-abcdefghijklmnopqrstuvwxyz"

# Jutge API base URL

export JUTGE_API_URL="https://api.jutge.org/api"

# reCAPTCHA v3 site key.
# Create at https://www.google.com/recaptcha/admin — choose reCAPTCHA v3.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
