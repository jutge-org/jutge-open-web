# Copy this file to `.env` and adjust values for local development.

# Secret (≥ 32 characters) used to sign session JWTs.
AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long

# Jutge API base URL (optional; defaults to https://api.jutge.org/api).
# JUTGE_API_URL=https://api.jutge.org/api

# Optional forwarded host header for API requests (production / reverse-proxy setups).
# JUTGE_DOMAIN=jutge.org

# Set by Next.js automatically in development and production.
# NODE_ENV=development
