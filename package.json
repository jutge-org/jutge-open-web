{
    "name": "open-jutge",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "update-jutge-client": "cd lib ; rm -f jutge_api_client.ts ; jutge clients typescript",
        "clean": "rm -rf .next",
        "dev": "bun --bun next dev",
        "build": "bun --bun next build",
        "start": "bun --bun next start",
        "format": "bun prettier --write --list-different .",
        "lint": "eslint",
        "knip": "knip",
        "deploy": "ssh -t minipc 'cd Projectes/open-jutge && pm2 stop open-jutge && git pull && bun install && bun run build && pm2 restart open-jutge'"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.5.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "shadcn": "^4.11.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^25.9.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19",
        "eslint": "^10.4.1",
        "eslint-config-next": "16.2.9",
        "knip": "^6.16.1",
        "prettier": "^3.8.4",
        "tailwindcss": "^4",
        "typescript": "^6.0.3"
    }
}
