{
    "name": "open-jutge",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "update-jutge-client": "cd lib ; rm -f jutge_api_client.ts ; jutge clients typescript",
        "clean": "rm -rf .next",
        "dev": "bun --bun next dev",
        "build": "bun --bun next build",
        "start": "bun --bun next start",
        "format": "bun prettier --write --list-different .",
        "lint": "eslint",
        "knip": "knip",
        "deploy": "ssh -t minipc 'cd Projectes/jutge-open-web && pm2 stop jutge && git pull && bun install && bun run build && pm2 restart jutge'"
